# OAuth 2.0 (required for get-token and auto-refresh)
TWITTER_CLIENT_ID=your_client_id_here
TWITTER_CLIENT_SECRET=your_client_secret_here
# Optional: set if you already have a bearer token (otherwise run get-token)
# TWITTER_BEARER_TOKEN=

# OAuth 1.0a (alternative auth method)
TWITTER_CONSUMER_KEY=your_consumer_key_here
TWITTER_CONSUMER_SECRET=your_consumer_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# Optional: redirect URI for serve command
TWITTER_REDIRECT_URI=https://your-tunnel-subdomain.trycloudflare.com/callback
